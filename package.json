{
  "name": "claudeck",
  "version": "1.3.1",
  "type": "module",
  "description": "A browser-based UI for Claude Code — chat, run workflows, manage MCP servers, track costs, and orchestrate autonomous agents from a local web interface. Installable as a PWA.",
  "main": "server.js",
  "bin": {
    "claudeck": "./cli.js"
  },
  "files": [
    "cli.js",
    "server.js",
    "db.js",
    "server/",
    "public/",
    "config/",
    "plugins/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "llm",
    "web-ui",
    "chat",
    "mcp",
    "agents",
    "workflows",
    "pwa",
    "developer-tools"
  ],
  "homepage": "https://github.com/hamedafarag/claudeck",
  "repository": {
    "type": "git",
    "url": "https://github.com/hamedafarag/claudeck"
  },
  "license": "MIT",
  "author": "Hamed Farag",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:perf": "vitest run --config vitest.config.perf.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.87",
    "@anthropic-ai/claude-agent-sdk": "^0.2.87",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "web-push": "^3.6.7",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "happy-dom": "^20.8.9",
    "supertest": "^7.2.2",
    "vitest": "^4.1.2"
  }
}
